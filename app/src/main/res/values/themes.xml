<resources>

    <style name="Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Personalizações do tema -->
    </style>

    <style name="Theme.MyApplication.Splash" parent="Theme.Material3.Light.NoActionBar">
        <item name="windowSplashScreenBackground">@color/background_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
        <item name="colorPrimary">@color/accent_yellow</item>
        <item name="colorPrimaryVariant">@color/accent_yellow_dark</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
    </style>

    <!-- Label section style -->
    <style name="TextAppearance.SectionLabel"
        parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_label</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Input field style -->
    <style name="Widget.AcademiaApp.InputField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/border_color</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>

    <!-- DatePicker escuro, com acento amarelo -->
    <style name="DatePickerTheme" parent="Theme.MaterialComponents.Dialog">
        <item name="colorPrimary">#F5C518</item>
        <item name="colorPrimaryVariant">#D4A800</item>
        <item name="colorOnPrimary">#1A1A1A</item>
        <item name="colorSurface">#242424</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:windowBackground">@null</item>
        <item name="android:datePickerStyle">@style/DatePickerStyle</item>
    </style>

    <style name="DatePickerStyle" parent="android:Widget.DatePicker">
        <item name="android:calendarViewShown">true</item>
        <item name="android:spinnersShown">false</item>
    </style>

</resources>