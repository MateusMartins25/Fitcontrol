<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0B1220">

    <!-- Título -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:text="Produtos"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <!-- Busca -->

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="#F4C542"
        app:boxStrokeColor="#F4C542"
        app:hintTextColor="@color/yellow_primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtBusca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar produtos..."
            android:textColor="#FFFFFF"/>

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Categorias -->

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategorias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="8dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Todos"
                android:checkable="true"
                android:textColor="@color/chip_text_color"
                app:chipBackgroundColor="@color/chip_background"
                app:selectionRequired="true"
                app:singleSelection="true"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="20dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBebidas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bebidas"
                android:checked="true"
                android:checkable="true"
                android:textColor="@color/chip_text_color"
                app:chipBackgroundColor="@color/chip_background"
                app:selectionRequired="true"
                app:singleSelection="true"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="20dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipComidas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comidas"
                android:checked="true"
                android:checkable="true"
                android:textColor="@color/chip_text_color"
                app:chipBackgroundColor="@color/chip_background"
                app:selectionRequired="true"
                app:singleSelection="true"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="20dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAcessorios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:checkable="true"
                android:text="Acessórios"
                android:textColor="@color/chip_text_color"
                app:chipBackgroundColor="@color/chip_background"
                app:selectionRequired="true"
                app:singleSelection="true"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="20dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSuplementos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:checkable="true"
                android:text="Suplementos"
                android:textColor="@color/chip_text_color"
                app:chipBackgroundColor="@color/chip_background"
                app:selectionRequired="true"
                app:singleSelection="true"
                app:chipStrokeWidth="0dp"
                app:chipCornerRadius="20dp" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Lista de produtos -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerProdutos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="8dp" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdicionarProduto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:contentDescription="Adicionar produto"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#FFD54F"
        app:tint="@android:color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</LinearLayout>