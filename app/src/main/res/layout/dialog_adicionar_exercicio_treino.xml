<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Adicionar exercício"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Exercício"
            android:textColor="#9E9E9E"
            android:textSize="12sp" />

        <Spinner
            android:id="@+id/spinnerExercicio"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/selector_ex_input" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Séries"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etSeriesDialog"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/selector_ex_input"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Repetições"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etRepeticoesDialog"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/selector_ex_input"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Carga (kg)"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etCargaDialog"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/selector_ex_input"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Descanso (s)"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/etDescansoDialog"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/selector_ex_input"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingHorizontal="12dp"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:text="Observações (opcional)"
            android:textColor="#9E9E9E"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/etObservacoesDialog"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@drawable/selector_ex_input"
            android:gravity="top"
            android:inputType="textMultiLine|textCapSentences"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnAdicionarExercicioDialog"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_btn_salvar"
            android:text="Adicionar"
            android:textColor="#121212"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
