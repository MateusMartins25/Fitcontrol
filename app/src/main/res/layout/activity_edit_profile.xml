<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#081226">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/btnVoltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/baseline_arrow_back_24"
            android:background="@android:color/transparent"
            app:tint="#E5C14D" />

        <!-- Cabeçalho -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar Perfil"
            android:textColor="@android:color/white"
            android:layout_gravity="center"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Atualize suas informações pessoais"
            android:textColor="#9AA3B2"
            android:textSize="14sp" />

        <!-- Foto -->

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_profile_circle">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:color="#000"
                android:src="@drawable/ic_user" />

        </FrameLayout>

        <Button
            android:id="@+id/btnChangePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:backgroundTint="#E5C14D"
            android:text="Alterar foto"
            android:textColor="#000"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:text="Informações pessoais"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            app:cardBackgroundColor="#111827"
            app:cardCornerRadius="16dp"
            app:strokeColor="#2A3550"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Nome -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="Nome"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edtNome"
                    style="@style/ProfileField"
                    android:hint="Digite seu nome" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="Peso"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edtPeso"
                    style="@style/ProfileField"
                    android:hint="Ex: 82 kg" />

                <!-- Altura -->

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="Altura"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edtAltura"
                    style="@style/ProfileField"
                    android:hint="Ex: 1,78 m" />

                <!-- Telefone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="Telefone"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edtTelefone"
                    style="@style/ProfileField"
                    android:hint="(47) 99999-9999" />

                <!-- Data -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="Data de nascimento"
                    android:textColor="#BBBBBB"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/edtDataNascimento"
                    style="@style/ProfileField"
                    android:hint="01/01/2000" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="#E5C14D"
            android:text="Salvar Alterações"
            android:textColor="#000"
            android:textStyle="bold"
            app:cornerRadius="28dp" />

    </LinearLayout>

</ScrollView>