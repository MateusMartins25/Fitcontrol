<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".ui.treino.CadastroTreinoActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#121212"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#121212"
            app:contentInsetEnd="0dp"
            app:contentInsetStart="0dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voltar"
                android:src="@drawable/baseline_arrow_back_24"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="52dp"
                android:gravity="center"
                android:text="Novo Treino"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.12"
                android:text="ALUNO"
                android:textColor="#6B6B6B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinnerUsuario"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/selector_ex_input" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.12"
                android:text="NOME DO TREINO"
                android:textColor="#6B6B6B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNomeTreino"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/selector_ex_input"
                android:hint="Ex: Treino A - Peito e Tríceps"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:paddingHorizontal="14dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#6B6B6B"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.12"
                android:text="GRUPO MUSCULAR (OPCIONAL)"
                android:textColor="#6B6B6B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etGrupoMuscular"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/selector_ex_input"
                android:hint="Ex: Peito, Tríceps"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:paddingHorizontal="14dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#6B6B6B"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.12"
                    android:text="EXERCÍCIOS"
                    android:textColor="#6B6B6B"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Button
                android:id="@+id/btnAdicionarExercicio"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/selector_ex_input"
                android:text="+ Adicionar exercício"
                android:textAllCaps="false"
                android:textColor="#7B61FF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerExercicios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvListaVazia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:padding="20dp"
                android:text="Nenhum exercício adicionado ainda"
                android:textColor="#6B6B6B"
                android:textSize="13sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#121212"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp">

        <Button
            android:id="@+id/btnSalvarTreino"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_btn_salvar"
            android:text="Salvar Treino"
            android:textColor="#121212"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
