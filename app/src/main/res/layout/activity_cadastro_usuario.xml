<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    tools:context=".ui.usuario.CadastroUsuarioActivity">

    <!-- ── Top App Bar ──────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1A1A1A"
            app:contentInsetEnd="0dp"
            app:contentInsetStart="0dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voltar"
                android:src="@drawable/baseline_arrow_back_24"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="52dp"
                android:gravity="center"
                android:text="Cadastro de Usuário"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Mais opções"
                android:src="@drawable/baseline_format_list_bulleted_24"
                app:tint="#FFFFFF" />

        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Conteúdo com scroll ──────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp">

            <!-- ── Avatar ─────────────────────────────────────────────── -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="28dp">

                <!-- Círculo do avatar -->
                <FrameLayout
                    android:id="@+id/containerAvatar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_avatar"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <!-- Ícone placeholder -->
                    <ImageView
                        android:id="@+id/ivAvatarPlaceholder"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_user"
                        app:tint="#616161" />

                    <!-- Foto do usuário -->
                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="Foto do usuário"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                </FrameLayout>

                <!-- Badge de edição (lápis amarelo) -->
                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_avatar_badge"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_edit"
                        app:tint="#1A1A1A" />
                </FrameLayout>
            </FrameLayout>

            <!-- ── NOME ────────────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.12"
                android:text="NOME COMPLETO"
                android:textColor="#757575"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/selector_input_field"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_user"
                    app:tint="#616161" />

                <EditText
                    android:id="@+id/etNome"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Ex: João Silva"
                    android:inputType="textPersonName|textCapWords"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#616161"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── TELEFONE ─────────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.12"
                android:text="TELEFONE"
                android:textColor="#757575"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/selector_input_field"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_phone"
                    app:tint="#616161" />

                <EditText
                    android:id="@+id/etTelefone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="(00) 00000-0000"
                    android:inputType="phone"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#616161"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── E-MAIL ───────────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.12"
                android:text="E-MAIL"
                android:textColor="#757575"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/selector_input_field"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_email"
                    app:tint="#616161" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Ex: joao@email.com"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#616161"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── DATA DE NASCIMENTO ───────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.12"
                android:text="DATA DE NASCIMENTO"
                android:textColor="#757575"
                android:textSize="11sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/containerDataNascimento"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/selector_input_field"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_calendario"
                    app:tint="#616161" />

                <TextView
                    android:id="@+id/tvDataNascimento"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:hint="dd/mm/aaaa"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#616161"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- ── ADMINISTRADOR ────────────────────────────────────────── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.12"
                android:text="PERMISSÕES"
                android:textColor="#757575"
                android:textSize="11sp"
                android:textStyle="bold" />

            <!-- Card de toggle Administrador -->
            <LinearLayout
                android:id="@+id/cardAdministrador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Ícone + textos -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_avatar_badge"
                    android:layout_marginEnd="14dp">

                    <ImageView
                        android:id="@+id/ivAdminIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_admin"
                        app:tint="#1A1A1A" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Administrador"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAdminDescricao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Sem acesso administrativo"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Switch -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAdministrador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    app:thumbTint="@color/selector_switch_thumb"
                    app:trackTint="@color/selector_switch_track" />

            </LinearLayout>

            <!-- Dica abaixo do card -->
            <TextView
                android:id="@+id/tvAdminDica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:text="Administradores têm acesso total ao sistema."
                android:textColor="#616161"
                android:textSize="12sp"
                app:drawableTint="#616161" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Botão Salvar fixo ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#1A1A1A"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="24dp">

        <Button
            android:id="@+id/btnSalvarUsuario"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_btn_salvar"
            android:drawableStart="@drawable/ic_check_circle"
            android:drawablePadding="8dp"
            android:gravity="center"
            android:text="Salvar Usuário"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
