<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="#1E1E1E"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="#2E2E2E"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Ícone lateral roxo -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_treino_icon">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_fitness"
                app:tint="#7B61FF" />
        </FrameLayout>

        <!-- Textos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Nome do treino -->
            <TextView
                android:id="@+id/tvNomeTreino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Grupo muscular -->
            <TextView
                android:id="@+id/tvGrupoMuscular"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#7B61FF"
                android:textSize="12sp" />

            <!-- Qtd de exercícios -->
            <TextView
                android:id="@+id/tvQuantidadeExercicios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawablePadding="4dp"
                android:textColor="#9E9E9E"
                android:textSize="12sp" />

            <!-- Última atualização -->
            <TextView
                android:id="@+id/tvUltimaAtualizacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#555555"
                android:textSize="11sp" />

        </LinearLayout>

        <!-- Seta de navegação -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:alpha="0.5"
            android:src="@drawable/ic_chevron_right"
            app:tint="#9E9E9E" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
