<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_product_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Product thumbnail -->
    <ImageView
        android:id="@+id/ivProdutoThumb"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@color/bg_secondary"
        android:contentDescription="Imagem do produto"
        android:scaleType="centerCrop"
        tools:src="@mipmap/ic_launcher" />

    <!-- Name & price -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProdutoNome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Gatorade Limão 500ml" />

        <TextView
            android:id="@+id/tvProdutoPreco"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            tools:text="R$ 8,90" />
    </LinearLayout>

    <!-- Badge Disponível -->
    <TextView
        android:id="@+id/tvProdutoStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_badge_disponivel"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textColor="@color/status_available_text"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:text="Disponível" />

</LinearLayout>
